{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@anthropic-ai/claude-code": ["src/shim/index.ts"]
    }
  },
  "include": ["src/**/*", "src/@types/**/*"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "files": true,
    "require": ["tsconfig-paths/register"]
  }
}
